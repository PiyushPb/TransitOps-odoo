meta {
  name: Create Maintenance Log
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/maintenance
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "vehicle_id": 1,
    "maintenance_type": "Oil Change",
    "maintenance_date": "2026-07-12T00:00:00Z",
    "cost": 150.00,
    "status": "In Progress"
  }
}
