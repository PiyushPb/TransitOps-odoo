meta {
  name: Create Fuel Log
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/expenses/fuel
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "vehicle_id": 1,
    "liters": 40.5,
    "price_per_liter": 1.5,
    "odometer": 1200,
    "fuel_date": "2026-07-14T00:00:00Z"
  }
}
