generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model roles {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(30)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users[]
}

model users {
  id               Int                @id @default(autoincrement())
  role_id          Int
  first_name       String             @db.VarChar(30)
  last_name        String             @db.VarChar(30)
  email            String             @unique @db.VarChar(255)
  password_hash    String
  phone            String?            @db.VarChar(15)
  profile_image    String?
  is_active        Boolean?           @default(true)
  last_login       DateTime?          @db.Timestamp(6)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  roles            roles              @relation(fields: [role_id], references: [id], onUpdate: NoAction)
  trips            trips[]
  maintenance_logs maintenance_logs[]
  activity_logs    activity_logs[]
  notifications    notifications[]
}

model vehicles {
  id                  Int                @id @default(autoincrement())
  registration_number String             @unique @db.VarChar(20)
  vehicle_name        String             @db.VarChar(50)
  model               String?            @db.VarChar(50)
  manufacturer        String?            @db.VarChar(50)
  manufacture_year    Int?
  vehicle_type        String             @db.VarChar(30)
  max_load_capacity   Decimal            @db.Decimal(10, 2)
  acquisition_cost    Decimal?           @db.Decimal(12, 2)
  fuel_type           String?            @db.VarChar(20)
  current_odometer    Int?               @default(0)
  status              String             @db.VarChar(20)
  region              String?            @db.VarChar(50)
  notes               String?
  purchase_date       DateTime?          @db.Date
  created_at          DateTime?          @default(now()) @db.Timestamp(6)
  updated_at          DateTime?          @default(now()) @db.Timestamp(6)
  trips               trips[]
  maintenance_logs    maintenance_logs[]
  fuel_logs           fuel_logs[]
  expenses            expenses[]
}

model drivers {
  id                  Int       @id @default(autoincrement())
  first_name          String    @db.VarChar(30)
  last_name           String    @db.VarChar(30)
  email               String?   @unique @db.VarChar(255)
  phone               String    @unique @db.VarChar(15)
  address             String?
  date_of_birth       DateTime? @db.Date
  emergency_contact   String?   @db.VarChar(15)
  license_number      String    @unique @db.VarChar(30)
  license_category    String    @db.VarChar(20)
  license_issue_date  DateTime  @db.Date
  license_expiry_date DateTime  @db.Date
  safety_score        Decimal?  @default(100) @db.Decimal(5, 2)
  status              String    @db.VarChar(20)
  joining_date        DateTime? @db.Date
  notes               String?
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)
  trips               trips[]
}

model routes {
  id               Int       @id @default(autoincrement())
  route_name       String    @db.VarChar(100)
  source           String    @db.VarChar(100)
  destination      String    @db.VarChar(100)
  distance         Decimal   @db.Decimal(10, 2)
  estimated_hours  Decimal?  @db.Decimal(5, 2)
  status           String    @default("Active") @db.VarChar(20)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  trips            trips[]
}

model trips {
  id               Int         @id @default(autoincrement())
  trip_number      String      @unique @db.VarChar(20)
  vehicle_id       Int
  driver_id        Int
  route_id         Int?
  created_by       Int
  source           String      @db.VarChar(100)
  destination      String      @db.VarChar(100)
  cargo_type       String?     @db.VarChar(100)
  cargo_weight     Decimal     @db.Decimal(10, 2)
  planned_distance Decimal     @db.Decimal(10, 2)
  actual_distance  Decimal?    @db.Decimal(10, 2)
  planned_start    DateTime    @db.Timestamp(6)
  actual_start     DateTime?   @db.Timestamp(6)
  actual_end       DateTime?   @db.Timestamp(6)
  fuel_consumed    Decimal?    @db.Decimal(10, 2)
  start_odometer   Int
  end_odometer     Int?
  revenue          Decimal?    @db.Decimal(12, 2)
  status           String      @db.VarChar(20)
  remarks          String?
  created_at       DateTime?   @default(now()) @db.Timestamp(6)
  updated_at       DateTime?   @default(now()) @db.Timestamp(6)
  vehicles         vehicles    @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)
  drivers          drivers     @relation(fields: [driver_id], references: [id], onUpdate: NoAction)
  routes           routes?     @relation(fields: [route_id], references: [id], onUpdate: NoAction)
  users            users       @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  fuel_logs        fuel_logs[]
  expenses         expenses[]
}

model maintenance_logs {
  id               Int       @id @default(autoincrement())
  vehicle_id       Int
  created_by       Int
  maintenance_type String    @db.VarChar(50)
  service_center   String?   @db.VarChar(100)
  maintenance_date DateTime  @db.Date
  completion_date  DateTime? @db.Date
  cost             Decimal   @db.Decimal(10, 2)
  status           String    @db.VarChar(20)
  description      String?
  remarks          String?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  vehicles         vehicles  @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)
  users            users     @relation(fields: [created_by], references: [id], onUpdate: NoAction)
}

model fuel_logs {
  id              Int       @id @default(autoincrement())
  vehicle_id      Int
  trip_id         Int?
  liters          Decimal   @db.Decimal(8, 2)
  price_per_liter Decimal   @db.Decimal(8, 2)
  total_cost      Decimal   @db.Decimal(10, 2)
  odometer        Int
  fuel_station    String?   @db.VarChar(100)
  fuel_date       DateTime  @db.Date
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  vehicles        vehicles  @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)
  trips           trips?    @relation(fields: [trip_id], references: [id], onUpdate: NoAction)
}

model expenses {
  id           Int       @id @default(autoincrement())
  vehicle_id   Int
  trip_id      Int?
  expense_type String    @db.VarChar(50)
  amount       Decimal   @db.Decimal(10, 2)
  description  String?
  expense_date DateTime  @db.Date
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  vehicles     vehicles  @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction)
  trips        trips?    @relation(fields: [trip_id], references: [id], onUpdate: NoAction)
}

model activity_logs {
  id          Int       @id @default(autoincrement())
  user_id     Int
  entity_type String    @db.VarChar(50)
  entity_id   Int
  action      String    @db.VarChar(50)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users     @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model notifications {
  id         Int       @id @default(autoincrement())
  user_id    Int
  title      String    @db.VarChar(100)
  message    String
  type       String    @db.VarChar(50)
  is_read    Boolean   @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}
