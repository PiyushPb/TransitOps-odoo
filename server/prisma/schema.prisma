generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model drivers {
  id                  Int       @id @default(autoincrement())
  first_name          String    @db.VarChar(30)
  last_name           String    @db.VarChar(30)
  email               String?   @unique @db.VarChar(255)
  phone_number        String    @unique @db.VarChar(15)
  address             String?
  date_of_birth       DateTime? @db.Date
  emergency_contact   String?   @db.VarChar(15)
  license_number      String    @unique @db.VarChar(30)
  license_category    String    @db.VarChar(20)
  license_issue_date  DateTime  @db.Date
  license_expiry_date DateTime  @db.Date
  joining_date        DateTime? @db.Date
  safety_score        Decimal?  @default(100) @db.Decimal(5, 2)
  status              String    @db.VarChar(20)
  notes               String?
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)
  trips               trips[]
}

model fuel_logs {
  id              Int       @id @default(autoincrement())
  vehicle_id      Int
  trip_id         Int?
  fuel_station    String?   @db.VarChar(100)
  liters          Decimal   @db.Decimal(8, 2)
  price_per_liter Decimal   @db.Decimal(8, 2)
  total_cost      Decimal   @db.Decimal(10, 2)
  odometer        Int
  fuel_date       DateTime  @db.Date
  created_by      Int
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  trips           trips?    @relation(fields: [trip_id], references: [id], onUpdate: NoAction, map: "fk_fuel_trip")
  users           users     @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_fuel_user")
  vehicles        vehicles  @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction, map: "fk_fuel_vehicle")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model maintenance_logs {
  id               Int       @id @default(autoincrement())
  vehicle_id       Int
  maintenance_type String    @db.VarChar(50)
  description      String?
  service_center   String?   @db.VarChar(100)
  maintenance_date DateTime  @db.Date
  completion_date  DateTime? @db.Date
  cost             Decimal   @db.Decimal(10, 2)
  status           String    @db.VarChar(20)
  remarks          String?
  created_by       Int
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  users            users     @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_maintenance_user")
  vehicles         vehicles  @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction, map: "fk_maintenance_vehicle")
}

model roles {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(30)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       users[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model trips {
  id               Int         @id @default(autoincrement())
  trip_number      String      @unique @db.VarChar(20)
  vehicle_id       Int
  driver_id        Int
  created_by       Int
  source           String      @db.VarChar(100)
  destination      String      @db.VarChar(100)
  cargo_type       String?     @db.VarChar(100)
  cargo_weight     Decimal     @db.Decimal(10, 2)
  planned_distance Decimal     @db.Decimal(10, 2)
  actual_distance  Decimal?    @db.Decimal(10, 2)
  planned_start    DateTime    @db.Timestamp(6)
  actual_start     DateTime?   @db.Timestamp(6)
  actual_end       DateTime?   @db.Timestamp(6)
  start_odometer   Int
  end_odometer     Int?
  fuel_consumed    Decimal?    @db.Decimal(10, 2)
  revenue          Decimal?    @db.Decimal(12, 2)
  status           String      @db.VarChar(20)
  remarks          String?
  created_at       DateTime?   @default(now()) @db.Timestamp(6)
  updated_at       DateTime?   @default(now()) @db.Timestamp(6)
  fuel_logs        fuel_logs[]
  drivers          drivers     @relation(fields: [driver_id], references: [id], onUpdate: NoAction, map: "fk_trip_driver")
  users            users       @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_trip_user")
  vehicles         vehicles    @relation(fields: [vehicle_id], references: [id], onUpdate: NoAction, map: "fk_trip_vehicle")
}

model users {
  id               Int                @id @default(autoincrement())
  f_name           String             @db.VarChar(30)
  l_name           String             @db.VarChar(30)
  role_id          Int
  email            String             @unique @db.VarChar(255)
  password_hash    String
  is_active        Boolean?           @default(true)
  last_login       DateTime?          @db.Timestamp(6)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  profile_image    String?
  phone_number     String?            @db.VarChar(15)
  fuel_logs        fuel_logs[]
  maintenance_logs maintenance_logs[]
  trips            trips[]
  roles            roles              @relation(fields: [role_id], references: [id], onUpdate: NoAction, map: "fk_user_role")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model vehicles {
  id                  Int                @id @default(autoincrement())
  registration_number String             @unique @db.VarChar(20)
  vehicle_name        String             @db.VarChar(50)
  model               String?            @db.VarChar(50)
  manufacturer        String?            @db.VarChar(50)
  manufacture_year    Int?
  vehicle_type        String             @db.VarChar(30)
  max_load_capacity   Decimal            @db.Decimal(10, 2)
  acquisition_cost    Decimal?           @db.Decimal(12, 2)
  fuel_type           String?            @db.VarChar(20)
  current_odometer    Int?               @default(0)
  status              String             @db.VarChar(20)
  region              String?            @db.VarChar(50)
  notes               String?
  purchase_date       DateTime?          @db.Date
  created_at          DateTime?          @default(now()) @db.Timestamp(6)
  updated_at          DateTime?          @default(now()) @db.Timestamp(6)
  fuel_logs           fuel_logs[]
  maintenance_logs    maintenance_logs[]
  trips               trips[]
}
